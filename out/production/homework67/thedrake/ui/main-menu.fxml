<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="thedrake.ui.MainMenuController"
           styleClass="root"
           stylesheets="@style.css"
           prefWidth="1280" prefHeight="720">

    <!-- Dark overlay for better text visibility -->
    <Region styleClass="dark-overlay"/>

    <!-- Main Content -->
    <VBox alignment="CENTER" spacing="40" maxWidth="500">
        <padding>
            <Insets top="50" right="50" bottom="50" left="50"/>
        </padding>

        <!-- Game Title -->
        <VBox alignment="CENTER" spacing="15">
            <Text text="THE DRAKE" styleClass="game-title">
                <font>
                    <Font name="System Bold" size="72"/>
                </font>
            </Text>
        </VBox>

        <!-- Menu Buttons -->
        <VBox spacing="20" alignment="CENTER" maxWidth="400">
            <Button fx:id="twoPlayersButton" text="Two Players"
                    styleClass="menu-button, active-button" onAction="#onTwoPlayers"
                    maxWidth="Infinity" minWidth="350" prefHeight="60">
                <font>
                    <Font name="System Bold" size="20"/>
                </font>
            </Button>

            <Button fx:id="vsComputerButton" text="Single Player vs Computer"
                    styleClass="menu-button, disabled-button" onAction="#onVsComputer"
                    maxWidth="Infinity" minWidth="350" prefHeight="60" disable="true">
                <font>
                    <Font name="System Bold" size="20"/>
                </font>
            </Button>

            <Button fx:id="onlineButton" text="Two Players Online"
                    styleClass="menu-button, disabled-button" onAction="#onOnline"
                    maxWidth="Infinity" minWidth="350" prefHeight="60" disable="true">
                <font>
                    <Font name="System Bold" size="20"/>
                </font>
            </Button>

            <Button fx:id="exitButton" text="Exit"
                    styleClass="menu-button, exit-button" onAction="#onExit"
                    maxWidth="Infinity" minWidth="350" prefHeight="60">
                <font>
                    <Font name="System Bold" size="20"/>
                </font>
            </Button>
        </VBox>
    </VBox>
</StackPane>